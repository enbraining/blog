---
import Header from '~/components/header.astro';
import { useI18n } from '~/i18n/utils';
import Main from '~/layouts/main.astro';

const { url } = Astro;
const { t, p } = useI18n(url);
---

<Main data-animate data-animate-speed="slow">
  <Header title="404">
    <p class="text-sm text-second">{t('404.desc')}</p>
  </Header>
  <section class="my-14">
    <a href={p('/')} class="link">cd ..</a>
  </section>
</Main>
